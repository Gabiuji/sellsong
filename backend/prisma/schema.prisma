datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// MODELO DE USUÁRIO (Atualizado com as relações)
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  // Relações virtuais do Prisma (não viram colunas físicas no banco)
  posts     Post[]
  followers Follow[] @relation("UserFollowers")
  following Follow[] @relation("UserFollowing")
  bio       String?  @db.Text // Biografia opcional do usuário
  avatarUrl String?  @db.Text// URL opcional para a foto de perfil do usuário
  stories       DailyStory[] // Relação com as histórias diárias do usuário
  topFour       TopFour[] // Relação com as 4 músicas favoritas do usuário
}

// MODELO DE POSTS (Resenhas Musicais)
model Post {
  id            Int      @id @default(autoincrement())
  spotifyTrackId String   // ID único da música que vem da API do Spotify
  trackName     String   // Nome da música (guardado para busca rápida no feed)
  artistName    String   // Nome do artista/banda
  albumCover    String   // URL da imagem da capa do álbum
  rating        Float    // Nota de 1 a 5 estrelas dado pelo usuário
  review        String?  // Texto opcional com a opinião do usuário
  createdAt     DateTime @default(now())

  // Chave estrangeira ligando o post ao autor
  userId        Int
  author        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// MODELO DE SEGUIDORES (Tabela intermediária para a rede social)
model Follow {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())

  // Quem está seguindo
  followerId  Int
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)

  // Quem está sendo seguido
  followingId Int
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  // Garante que um usuário não siga a mesma pessoa duas vezes
  @@unique([followerId, followingId])
}
// Modelo para as Recomendações Diárias (Stories)
model DailyStory {
  id             Int      @id @default(autoincrement())
  userId         Int
  spotifyTrackId String
  trackName      String
  artistName     String
  albumCover     String
  previewUrl     String?  // Necessário para o player de micro-audição!
  spotifyUrl     String?  // Link para a página da música no Spotify
  caption        String   // Breve descrição (limite de 150 caracteres validado no front/back)
  genreTag       String   // Tag do gênero musical
  createdAt      DateTime @default(now())

  author         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Modelo para as 4 Músicas Favoritas do Perfil
model TopFour {
  id             Int      @id @default(autoincrement())
  userId         Int
  position       Int      // Posição de 1 a 4 fixada
  spotifyTrackId String
  trackName      String
  artistName     String
  albumCover     String

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, position]) // Garante apenas uma música por slot do top 4
}
# ==========================================
# DATABASE
# ==========================================
DATABASE_URL="postgresql://postgres:password123@postgres_db:5432/sellsong"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password123
POSTGRES_DB=sellsong

# ==========================================
# AUTHENTICATION
# ==========================================
# Use uma string aleatória forte (mínimo 32 caracteres)
# Gerar com: openssl rand -base64 32
JWT_SECRET=sua_chave_jwt_super_secreta_aqui_minimo_32_caracteres
JWT_EXPIRY=24h

# ==========================================
# SERVER
# ==========================================
PORT=3000
NODE_ENV=development

# ==========================================
# CORS
# ==========================================
# URL do frontend (ajustar conforme ambiente)
FRONTEND_URL=http://localhost:5173

# ==========================================
# SPOTIFY API
# ==========================================
SPOTIFY_CLIENT_ID=seu_client_id_aqui
SPOTIFY_CLIENT_SECRET=seu_client_secret_aqui

# ==========================================
# RATE LIMITING
# ==========================================
# Número máximo de requisições por janela de tempo
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
